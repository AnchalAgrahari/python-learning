import logging

logging.basicConfig(level=logging.INFO, filename="log.log", filemode="w",
                    format="%(asctime)s - %(levelname)s - %(message)s")

#we simply put the name of the logg and it shows the logger and if not exist it will create
logger = logging.getLogger(__name__)

handler = logging.FileHandler('test.log') #handler is use to seperate the file from originl(log.log)
formatter = logging.Formatter('%(asctime)s - %(name)s - %(levelname)s - %(message)s')
handler.setFormatter(formatter)

logger.addHandler(handler)


logger.info("test the logger")